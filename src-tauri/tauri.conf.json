{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TiTiTalk",
  "version": "0.15.0",
  "identifier": "com.tititalk.windows",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TiTiTalk",
        "url": "index.html",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "visible": false,
        "center": true
      },
      {
        "label": "pill",
        "title": "TiTiTalk Pill",
        "url": "pill.html",
        "width": 240,
        "height": 48,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": false,
        "shadow": false
      },
      {
        "label": "assistant",
        "title": "TiTiTalk · 随便问",
        "url": "assistant.html",
        "width": 640,
        "height": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "publisher": "TiTiTalk",
    "shortDescription": "语音输入法 · 按住快捷键说话",
    "longDescription": "TiTiTalk Windows — 按住快捷键说话，松开自动转写到光标处。微信、邮件、IDE、Notion 全都能用。",
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "displayLanguageSelector": false
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://tititalk.com/downloads/windows-update.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlENDhERkZDODRBNkE2RjcKUldUM3BxYUUvTjlJblZRaER1TXptMzhBaCtwbkU1NzN3WXlxekNMUGM0R3VkY3lvcHZ1SkQ2aGcK"
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "tititalk"
        ]
      }
    }
  }
}
